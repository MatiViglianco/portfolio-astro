---
import ProjectItem from './ProjectItem.astro';
import cuentaCorrienteImg from '../assets/cuentaCorriente.jpg';
import coinLatamImg from '../assets/coinLatam.png';
import p2pImg from '../assets/p2p.jpg';
import itbankImg from '../assets/itbank.png';
import naranja1Img from '../assets/naranja1.jpg';
import naranja2Img from '../assets/naranja2.jpg';
import naranja3Img from '../assets/naranja3.jpg';
import erp1Img from '../assets/erp1.jpg';
import erp2Img from '../assets/erp2.jpg';
import erp3Img from '../assets/erp3.jpg';
import erp4Img from '../assets/erp4.jpg';
import erp5Img from '../assets/erp5.jpg';
import erp6Img from '../assets/erp6.jpg';
import erp7Img from '../assets/erp7.jpg';
import erp8Img from '../assets/erp8.jpg';
import erp9Img from '../assets/erp9.jpg';
import crm1Img from '../assets/crm1.jpg';
import crm2Img from '../assets/crm2b.jpg';
import ops1Img from '../assets/ops1.jpg';
import ops2Img from '../assets/ops2.jpg';
import conciliar1Img from '../assets/conciliar1.jpg';
import conciliar2Img from '../assets/conciliar2.jpg';
import vales1Img from '../assets/vales1.jpg';
import vales2Img from '../assets/vales2.jpg';
import cartaPorteImg from '../assets/cartaPorte.svg';
import aumaxImg from '../assets/aumax.svg';
import recibosImg from '../assets/recibos.svg';

const PROJECTS = [
    {
        id_prefix: 'proj8',
        title: 'CRM Multi-canal de WhatsApp',
        description: 'Monitor operativo tipo CRM que unifica varios números de WhatsApp de la empresa (clientes, equipo interno y cartas de porte) en una sola bandeja: conversaciones con estados de resolución, salud de colas por canal, alertas, historial, audios y reportes. Frontend React contra API REST de Django. Proyecto privado para MolinosMarimbo.',
        images: [crm1Img, crm2Img],
        tags: ['React', 'Django', 'DRF', 'WhatsApp Cloud API', 'PostgreSQL', 'Docker'],
        demoUrl: 'https://crm.marimbo.cloud/'
    },
    {
        id_prefix: 'proj12',
        title: 'Transcripción y Resumen de Audios con IA',
        description: 'Sistema productivo que recibe audios de vendedores por WhatsApp Cloud API y los procesa de forma asíncrona: descarga, conversión, transcripción y resumen con IA (Gemini/OpenAI), panel con filtros y estadísticas por vendedor, y campañas por templates aprobados en Meta. Proyecto privado para MolinosMarimbo.',
        images: [ops1Img, ops2Img],
        tags: ['Django', 'Celery', 'Redis', 'PostgreSQL', 'Gemini', 'WhatsApp Cloud API', 'Docker']
    },
    {
        id_prefix: 'proj9',
        title: 'Bot de Cartas de Porte Electrónicas (ARCA)',
        description: 'Bot conversacional de WhatsApp que guía a los clientes en la confección de Cartas de Porte electrónicas: captura los datos por diálogo con máquina de estados y sesiones persistentes, valida y emite la CPE ante ARCA (WSCPE, SOAP/WSAA) devolviendo número de CPE y CTG en el momento. Proyecto privado para MolinosMarimbo.',
        image: cartaPorteImg,
        tags: ['Python', 'Django', 'ARCA/WSCPE', 'SOAP', 'WhatsApp Cloud API', 'Celery']
    },
    {
        id_prefix: 'proj10',
        title: 'Tickets de Descarga de Camiones (Balanza + ARCA)',
        description: 'Módulo que se integra con el sistema de balanza (axControl) para tomar los datos reales de cada descarga de camiones y con ARCA (WSCPE) para confeccionar el ticket de ingreso en PDF —CTG, carta de porte, grano, procedencia/destino y pesos— y enviárselo automáticamente al transportista por WhatsApp. Proyecto privado para MolinosMarimbo.',
        image: aumaxImg,
        tags: ['Python', 'Django', 'ARCA/WSCPE', 'SOAP', 'PyMuPDF', 'WhatsApp Cloud API']
    },
    {
        id_prefix: 'proj11',
        title: 'Recibos de Sueldo por WhatsApp con Firma Digital',
        description: 'Módulo de RRHH que parsea el PDF maestro de recibos por página, hace matching por DNI y nombre contra empleados, firma digitalmente cada recibo (certificado P12/PFX) y lo envía por WhatsApp mediante un portal seguro con validación OTP, auditoría de eventos y reintentos asíncronos. Proyecto privado para MolinosMarimbo.',
        image: recibosImg,
        tags: ['Django', 'Celery', 'Firma Digital', 'OTP', 'WhatsApp Cloud API', 'PostgreSQL']
    },
    {
        id_prefix: 'proj13',
        title: 'Conciliación Bancaria Automática con IA',
        description: 'Backend Django/DRF para conciliación bancaria automática y asistida por IA. Importa extractos XLSX de 6 bancos argentinos, propone matches validados localmente y deja la decisión final a un operador vía API. Stack con Celery, MinIO y despliegue en Dokploy. Proyecto privado para MolinosMarimbo.',
        images: [conciliar1Img, conciliar2Img],
        tags: ['Django', 'DRF', 'Gemini', 'Celery', 'PostgreSQL', 'MinIO', 'Docker']
    },
    {
        id_prefix: 'proj7',
        title: 'Vales OCR: Digitalización de Vales Manuscritos',
        description: 'Plataforma web que digitaliza vales manuscritos con OCR asistido por IA: carga de fotos, extracción de datos, match contra clientes reales con alias sugeridos, revisión manual y carga de lotes al ERP. Frontend React con JWT y CSP estricta, deploy automático con GitHub Actions y Dokploy.',
        images: [vales1Img, vales2Img],
        tags: ['React', 'Django', 'OCR', 'Gemini', 'JWT', 'Nginx', 'GitHub Actions'],
        demoUrl: 'https://vales.mativiglianco.cloud/'
    },
    {
        id_prefix: 'proj5',
        title: 'Naranja Autoservicio (e-commerce Django + React)',
        description: 'Tienda online para autoservicio con Django/DRF y Vite/React. Catálogo, stock, cupones y órdenes; carrito persistente y checkout por WhatsApp. Búsqueda sin acentos, promociones y estadísticas en el admin. CI/CD en Dokploy con Postgres.',
        images: [naranja1Img, naranja2Img, naranja3Img],
        tags: ['Django', 'Django REST Framework', 'React', 'Vite', 'PostgreSQL', 'CI/CD', 'Docker']
    },
    {
        id_prefix: 'proj6',
        title: 'ERP Interno de Operaciones y Finanzas (Kretz)',
        description: 'ERP interno con módulos de ventas, gastos, cuentas corrientes y estadísticas. Integra datos bancarios, carga manual de egresos, clasificación por categorías y visualizaciones con gráficos. Stack: Django/DRF, React, MUI, Chart.js, PostgreSQL, JWT y Docker. Enfoque en performance, consistencia de datos y experiencia de usuario.',
        images: [erp1Img, erp2Img, erp3Img, erp4Img, erp5Img, erp6Img, erp7Img, erp8Img, erp9Img],
        tags: ['Django', 'Django REST Framework', 'React', 'MUI', 'Chart.js', 'PostgreSQL', 'JWT', 'Docker']
    },
    { id_prefix: 'proj1', title: 'AppCuentaCorriente: Gestión de Clientes', description: 'Aplicación web para la gestión de cuentas corrientes de clientes, usando localStorage para persistir los datos. Permite registrar clientes, transacciones y pagos.', image: cuentaCorrienteImg, tags: ['React', 'TypeScript', 'Vite', 'Tailwind CSS'], demoUrl: 'https://mativiglianco.github.io/AppCuentaCorriente/', repoUrl: 'https://github.com/MatiViglianco/AppCuentaCorriente' },
    { id_prefix: 'proj2', title: 'CoinLatam: Interacción con Criptomonedas', description: 'Proyecto que ofrece cotizaciones de criptomonedas en tiempo real con una interfaz moderna y fluida.', image: coinLatamImg, tags: ['React', 'Next.js', 'Node.js', 'MongoDB'], demoUrl: '#', repoUrl: 'https://github.com/julianvidela/coin-latam' },
    { id_prefix: 'proj3', title: 'P2Pbetting: A Chainlink Hackathon', description: 'Plataforma descentralizada y segura para apuestas P2P basada en contratos inteligentes en la blockchain.', image: p2pImg, tags: ['Solidity', 'React', 'Hardhat', 'Chainlink'], demoUrl: 'https://martinllobell.github.io/dapp/', repoUrl: 'https://github.com/martinllobell/dapp' },
    { id_prefix: 'proj4', title: 'ITBANK: Banco Virtual', description: 'Plataforma web de un banco virtual para la gestión de clientes y operaciones financieras.', image: itbankImg, tags: ['Javascript', 'Django', 'PostgreSQL', 'CSS', 'Bootstrap', 'API REST'], demoUrl: '#', repoUrl: 'https://github.com/ItbaGrupo5' }
];
---
<section id="projects" class="py-20">
    <h2 class="section-title text-3xl font-bold text-white mb-12 flex items-center reveal-on-scroll" data-translate="projects_title">
        Proyectos Destacados
    </h2>
    <div class="space-y-12">
        {PROJECTS.map(project => (
            <ProjectItem {...project} />
        ))}
    </div>
</section>
