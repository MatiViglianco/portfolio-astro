---
// src/components/Experience.astro
import ExperienceItem from './ExperienceItem.astro';

const EXPERIENCES = [
    {
        id_prefix: 'exp1',
        date: 'feb 2026 - Presente',
        title: 'AI Integrations & Backend Engineer',
        company: 'MolinosMarimbo',
        descriptions: [
            'Diseño y desarrollo una suite interna de CRM comercial, conciliación financiera, migración de ERP legacy y reporting operativo con Django, DRF y React.',
            'Integro Meta/WhatsApp Business Platform vía webhooks: captura de mensajes, transcripción y resumen de audios comerciales con IA, campañas por templates y bots conversacionales.',
            'Desarrollo integraciones con AFIP/ARCA (WSCPE, SOAP/WSAA) para Cartas de Porte electrónicas y tickets de descarga enviados por WhatsApp.',
            'Implemento importaciones masivas, deduplicación, snapshots y procesamiento asíncrono con Celery, Redis y almacenamiento S3/MinIO, desplegado con Docker y CI/CD.'
        ]
    },
    {
        id_prefix: 'exp2',
        date: 'feb 2025 - Presente',
        title: 'Full Stack Developer | Automatización, Datos & Web3',
        company: 'Freelancer.com',
        descriptions: [
            'Construyo aplicaciones internas con Django/DRF, React, PostgreSQL y Docker para procesos administrativos y financieros.',
            'Desarrollo automatizaciones desktop (.exe) para facturación automática y bots conectados a APIs externas, incluyendo un bot de trading de futuros en Binance.',
            'Desarrollo proyectos Web3 con Solidity: smart contracts, NFTs, tokens y experimentos con Chainlink.',
            'Despliegues en VPS con pipelines de CI/CD usando Docker, GitHub Actions y Dokploy.'
        ]
    },
    {
        id_prefix: 'exp3',
        date: 'jun 2023 - ene 2025',
        title: 'Ingeniero de IA / Prompt Engineer',
        company: 'Revelo',
        descriptions: [
            'Evaluación sistemática de outputs de IA (factualidad, consistencia, formato, edge cases) con reporte de hallazgos accionables.',
            'Análisis con Python (Pandas, PyTorch, Matplotlib) para identificar patrones de error y oportunidades de mejora.',
            'Contribuí a mejorar ~30% la precisión en un caso de uso de búsqueda de vuelos mediante validación e iteración sobre la integración vía API.'
        ]
    }
];
---
<section id="experience" class="py-20 reveal-on-scroll">
    <h2 class="section-title text-3xl font-bold text-white mb-12 flex items-center" data-translate="experience_title">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 mr-2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.07a2.25 2.25 0 01-2.25 2.25H5.92a2.25 2.25 0 01-2.25-2.25v-4.07a2.25 2.25 0 01.528-1.48L5.84 9.44a2.25 2.25 0 013.18 0l2.12 2.12a2.25 2.25 0 003.18 0l2.12-2.12a2.25 2.25 0 013.18 0l2.472 2.472a2.25 2.25 0 01.528 1.48z" /></svg>
        Experiencia Profesional
    </h2>
    <div class="relative border-l-2 border-purple-500/30 pl-10 space-y-12">
        {EXPERIENCES.map(exp => (
            <ExperienceItem {...exp} />
        ))}
    </div>
</section>
